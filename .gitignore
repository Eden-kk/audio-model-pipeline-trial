# env / secrets
.env
.env.local
.env.*.local
*.pem
*.key

# python
__pycache__/
*.pyc
*.pyo
.venv/
venv/
.mypy_cache/
.pytest_cache/
.ruff_cache/
*.egg-info/
dist/
build/

# node / vite
node_modules/
frontend/dist/
frontend/.vite/
.DS_Store

# audio + run artifacts (clip / run storage is on the server volume, not in git)
data/
clips/
runs/
*.wav
*.mp3
*.opus
*.webm
!frontend/public/**/*.wav

# editor
.vscode/
.idea/
*.swp

# logs
*.log
logs/

# Backend local data (clips and run logs — not committed). The README is
# the only file that *is* tracked so the layout doc travels with the repo.
# Re-include the dir explicitly because the broader `data/` pattern above
# would otherwise exclude `backend/data/` and prevent any `!` rescue.
!backend/data/
backend/data/*
!backend/data/README.md
