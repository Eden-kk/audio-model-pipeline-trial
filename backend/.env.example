# Copy to .env and fill in values before starting the backend.

# ── ASR adapters (cloud) ────────────────────────────────────────────────────
# Each is optional — adapters without keys are still listed in /api/adapters
# but raise a clear runtime error when invoked. faster_whisper requires no key.

DEEPGRAM_API_KEY=your_deepgram_api_key_here          # adapter: deepgram
GLADIA_API_KEY=your_gladia_api_key_here              # adapter: gladia
ASSEMBLYAI_API_KEY=your_assemblyai_api_key_here      # adapter: assemblyai
SPEECHMATICS_API_KEY=your_speechmatics_api_key_here  # adapter: speechmatics
GROQ_API_KEY=your_groq_api_key_here                  # adapter: groq_whisper

# ── ASR adapters (self-host via remote model-server) ────────────────────────
# Slice 1B introduces a model-server container that hosts NeMo (Parakeet,
# Canary-1B-flash, Canary-Qwen-2.5B) on the AMD remote machine.

MODEL_SERVER_URL=http://localhost:9100               # adapters: parakeet, canary_1b_flash, canary_qwen_25b

# ── TTS / speaker-verify ────────────────────────────────────────────────────
CARTESIA_API_KEY=your_cartesia_api_key_here          # adapter: cartesia_tts
HF_TOKEN=your_hf_token_here                          # adapter: pyannote_verify (accept license at hf.co/pyannote/embedding)

# ── Backend infrastructure ──────────────────────────────────────────────────
FRONTEND_ORIGIN=http://localhost:5173
DATA_DIR=data
