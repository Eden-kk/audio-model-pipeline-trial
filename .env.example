# Audio-model trial — deployment-time environment.
#
# Copy to `.env` (next to docker-compose.yml) and fill in.
# `docker compose up -d --build` reads this file automatically.

# ── Public hostname & TLS ────────────────────────────────────────────────────
PUBLIC_HOST=audio-trial.example.com
PUBLIC_ORIGIN=https://audio-trial.example.com
LETSENCRYPT_EMAIL=you@example.com

# ── ROCm — GPU architecture override (model-server, AMD lane only) ─────────
# Leave blank for MI300X / MI250X (auto-detected).
# Consumer Navi 31 (7900 XTX, 7900 XT, 7900 GRE): set to 11.0.0
# Consumer Navi 22 (6700 XT, 6800 XT): set to 10.3.0
HSA_OVERRIDE_GFX_VERSION=

# ── Self-host backend selection ─────────────────────────────────────────────
# Pick ONE of: modal | amd | local.  Default = modal so a fresh clone hits the
# documented Modal deploy. Flip to "local" on a NVIDIA CUDA box (B200, H100,
# A100, etc.) and to "amd" on a ROCm box.
MODEL_SERVER_BACKEND=modal
# Local CUDA URL (native venv via model-server/run-cuda.sh, OR docker via
# model-server/docker-compose.cuda.yml on a docker-enabled host).
MODEL_SERVER_LOCAL_URL=http://localhost:9100
MODEL_SERVER_AMD_URL=http://localhost:9100
# Public Modal URL printed by `modal deploy model-server/modal_app.py`.
MODEL_SERVER_MODAL_URL=
# Where local model weights cache (NeMo + HF). Pick a roomy mount; do NOT
# leave it under $HOME if /home is small. Used by run-cuda.sh + run-vllm.sh.
MODEL_CACHE_DIR=/raid/yid042/audio-trial-models

# ── ASR adapters (cloud) ────────────────────────────────────────────────────
DEEPGRAM_API_KEY=
GLADIA_API_KEY=
ASSEMBLYAI_API_KEY=
SPEECHMATICS_API_KEY=
GROQ_API_KEY=

# ── TTS / speaker-verify ────────────────────────────────────────────────────
CARTESIA_API_KEY=
HF_TOKEN=                  # accept the license at hf.co/pyannote/embedding first

# ── Storage ─────────────────────────────────────────────────────────────────
DATA_DIR=/app/data         # inside the trial-app container; mapped to volume
