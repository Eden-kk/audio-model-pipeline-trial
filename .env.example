# Audio-model trial — deployment-time environment.
#
# Copy to `.env` (next to docker-compose.yml) and fill in.
# `docker compose up -d --build` reads this file automatically.

# ── Public hostname & TLS ────────────────────────────────────────────────────
PUBLIC_HOST=audio-trial.example.com
PUBLIC_ORIGIN=https://audio-trial.example.com
LETSENCRYPT_EMAIL=you@example.com

# ── ROCm — GPU architecture override (model-server) ─────────────────────────
# Leave blank for MI300X / MI250X (auto-detected).
# Consumer Navi 31 (7900 XTX, 7900 XT, 7900 GRE): set to 11.0.0
# Consumer Navi 22 (6700 XT, 6800 XT): set to 10.3.0
HSA_OVERRIDE_GFX_VERSION=

# ── ASR adapters (cloud) ────────────────────────────────────────────────────
DEEPGRAM_API_KEY=
GLADIA_API_KEY=
ASSEMBLYAI_API_KEY=
SPEECHMATICS_API_KEY=
GROQ_API_KEY=

# ── TTS / speaker-verify ────────────────────────────────────────────────────
CARTESIA_API_KEY=
HF_TOKEN=                  # accept the license at hf.co/pyannote/embedding first

# ── Storage ─────────────────────────────────────────────────────────────────
DATA_DIR=/app/data         # inside the trial-app container; mapped to volume
