{"openapi":"3.1.0","info":{"title":"audio-trial-backend","version":"0.1.0"},"paths":{"/api/health":{"get":{"summary":"Health","operationId":"health_api_health_get","responses":{"200":{"description":"Successful Response","content":{"application/json":{"schema":{}}}}}}},"/api/adapters":{"get":{"summary":"List Adapters","description":"List registered adapters. Optional ?category=asr|tts|speaker_verify filter.\n\nReturns a flat list (REST convention) — frontend expects `Adapter[]` directly.","operationId":"list_adapters_api_adapters_get","parameters":[{"name":"category","in":"query","required":false,"schema":{"anyOf":[{"type":"string"},{"type":"null"}],"title":"Category"}}],"responses":{"200":{"description":"Successful Response","content":{"application/json":{"schema":{}}}},"422":{"description":"Validation Error","content":{"application/json":{"schema":{"$ref":"#/components/schemas/HTTPValidationError"}}}}}}},"/api/clips":{"get":{"summary":"Get Clips","operationId":"get_clips_api_clips_get","responses":{"200":{"description":"Successful Response","content":{"application/json":{"schema":{"additionalProperties":true,"type":"object","title":"Response Get Clips Api Clips Get"}}}}}},"post":{"summary":"Upload Clip","description":"Accept an audio OR video file. Video containers (.mp4, .mov, .webm, .mkv,\n.avi, .m4v, .ts, .mts) get their audio track extracted to wav-16k-mono via\nffmpeg; the original is kept adjacent for reference. Adapters always read\nthe canonical wav.","operationId":"upload_clip_api_clips_post","requestBody":{"content":{"multipart/form-data":{"schema":{"$ref":"#/components/schemas/Body_upload_clip_api_clips_post"}}},"required":true},"responses":{"201":{"description":"Successful Response","content":{"application/json":{"schema":{"$ref":"#/components/schemas/ClipOut"}}}},"422":{"description":"Validation Error","content":{"application/json":{"schema":{"$ref":"#/components/schemas/HTTPValidationError"}}}}}}},"/api/clips/{clip_id}":{"patch":{"summary":"Update Clip","description":"Mutate a clip's user_tags / scenarios + auto-tagger metadata —\nused by the Corpus page chip tagger and the ingest auto-tagger.\nOther fields (id / format / duration_s / etc.) are immutable\npost-ingest by design.","operationId":"update_clip_api_clips__clip_id__patch","parameters":[{"name":"clip_id","in":"path","required":true,"schema":{"type":"string","title":"Clip Id"}}],"requestBody":{"required":true,"content":{"application/json":{"schema":{"$ref":"#/components/schemas/ClipPatch"}}}},"responses":{"200":{"description":"Successful Response","content":{"application/json":{"schema":{"$ref":"#/components/schemas/ClipOut"}}}},"422":{"description":"Validation Error","content":{"application/json":{"schema":{"$ref":"#/components/schemas/HTTPValidationError"}}}}}},"delete":{"summary":"Delete Clip","operationId":"delete_clip_api_clips__clip_id__delete","parameters":[{"name":"clip_id","in":"path","required":true,"schema":{"type":"string","title":"Clip Id"}}],"responses":{"204":{"description":"Successful Response"},"422":{"description":"Validation Error","content":{"application/json":{"schema":{"$ref":"#/components/schemas/HTTPValidationError"}}}}}}},"/api/clips/{clip_id}/autotag":{"post":{"summary":"Autotag Clip Endpoint","description":"Run the heuristic auto-tagger on a single clip and persist the\ndetected scenarios to its manifest. Returns the detected list +\nfeature values + per-tag evidence so the UI can show \"why\".","operationId":"autotag_clip_endpoint_api_clips__clip_id__autotag_post","parameters":[{"name":"clip_id","in":"path","required":true,"schema":{"type":"string","title":"Clip Id"}}],"requestBody":{"content":{"application/json":{"schema":{"anyOf":[{"$ref":"#/components/schemas/AutoTagOptions"},{"type":"null"}],"title":"Opts"}}}},"responses":{"200":{"description":"Successful Response","content":{"application/json":{"schema":{"$ref":"#/components/schemas/AutoTagResult"}}}},"422":{"description":"Validation Error","content":{"application/json":{